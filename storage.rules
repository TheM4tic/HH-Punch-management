rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Photo uploads ─────────────────────────────────────────────────────
    match /photos/{itemId}/{photoId} {
      // Any authenticated user can read and upload photos
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024          // 15 MB max per photo
        && request.resource.contentType.matches('image/(jpeg|png|gif|webp|heic|heif)');
      allow delete: if request.auth != null;
    }

    // ── Project config (logo) ─────────────────────────────────────────────
    match /config/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024           // 2 MB max for logo
        && request.resource.contentType.matches('image/(jpeg|png|gif|webp)');
      allow delete: if request.auth != null;
    }

    // ── Block everything else ────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
